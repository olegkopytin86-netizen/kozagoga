# ═══════════════════════════════════════════════════════
# Kozagogo Marketplace — Environment Variables
# ═══════════════════════════════════════════════════════
# Копируйте в .env и заполните своими значениями
# ═══════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────
API_PORT=3001
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# ─── JWT ──────────────────────────────────────────────
# !!! Обязательно замените на минимум 256-битный ключ !!!
JWT_SECRET=change-this-to-a-strong-secret-at-least-32-chars

# ─── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kozagogo
DB_USER=kozagogo
DB_PASS=change-this-password

# ─── Hyperion Provider ────────────────────────────────
HYPERION_BASE_URL=https://dev-funnel-p1.rps.kg/api/webhub
HYPERION_LOGIN=your-login@example.com
HYPERION_PASSWORD=your-password
HYPERION_DEALER=your-dealer-id
HYPERION_CURRENCY=KGS

# ─── Sberbank Payments ────────────────────────────────
SBER_LOGIN=sbertest_82
SBER_PASSWORD=your-sber-password
SBER_BASE_URL=https://ecomtest.sberbank.ru/ecomm/gw/partner/api/v1
SBER_RETURN_URL=https://your-domain.com/orders
SBER_FAIL_URL=https://your-domain.com/checkout
SBER_NOTIFICATION_URL=https://your-domain.com/api/payments/webhook/sberbank
SBER_TWO_STAGE=false
SBER_SESSION_TIMEOUT=1200

# ─── YooKassa ─────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ─── Webhook IP Filtering ──────────────────────────────
# Список IP адресов платёжных систем (через запятую)
# В production: узнайте IP-диапазоны Сбера и ЮKassa
SBER_WEBHOOK_IPS=
YOOKASSA_WEBHOOK_IPS=

# ─── Telegram Bot ─────────────────────────────────────
BOT_TOKEN=
